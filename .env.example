# Env vars used by the Playwright E2E suite (e2e/).
# Copy to .env (gitignored) and fill in for local runs, or export inline:
#   JWT_SECRET=<secret> npm run e2e

# HS256 signing secret used by api.cashbff.com. Required.
# Lives as JWT_SECRET on the Render service for CashBFF-Plaid-API.
JWT_SECRET=

# Test user identity. Defaults match Daksh's prod account; override to run
# the suite against a different user.
TEST_UID=user_19095425819
TEST_PHONE=+19095425819
TEST_SV=1
